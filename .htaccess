# Apache + PHP 8.2 FPM (CodeIgniter)
# "No input file specified" is caused by PATH_INFO reaching FPM — rules below avoid that.

Options All -Indexes
Options -MultiViews

DirectoryIndex index.php index.html

# Block PATH_INFO on the front controller (critical for PHP-FPM)
<Files "index.php">
	AcceptPathInfo Off
</Files>

# Pass Authorization header through to PHP-FPM
<IfModule mod_setenvif.c>
	SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# PHP 8.2 FPM handler — uncomment ONE block and set your socket path.
# Find the socket: ls /run/php/ or ls /var/run/php/
#
# <IfModule proxy_fcgi_module>
# 	<FilesMatch \.php$>
# 		SetHandler "proxy:unix:/run/php/php8.2-fpm.sock|fcgi://localhost/"
# 	</FilesMatch>
# </IfModule>
#
# cPanel / CloudLinux example:
# <IfModule mime_module>
# 	AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
# </IfModule>

<IfModule mod_proxy_fcgi.c>
	ProxyFCGIBackendType GENERIC
</IfModule>

<IfModule mod_rewrite.c>
	Options +FollowSymlinks
	RewriteEngine On

	# Uncomment if the app is in a subfolder, e.g.:
	# RewriteBase /national-performance-dashboard/

	# Pass Authorization header (backup for mod_setenvif)
	RewriteCond %{HTTP:Authorization} .
	RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

	# Redirect trailing slashes (relative — safe in subfolders)
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_URI} (.+)/$
	RewriteRule ^ %1 [L,R=301]

	# Route to index.php without appending a path (PHP-FPM safe)
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^ index.php [L]
</IfModule>

# Apache 2.4+ front-controller fallback (also PHP-FPM safe)
<IfModule mod_dir.c>
	FallbackResource index.php
</IfModule>

<IfModule mod_authz_core.c>
	RedirectMatch 404 /\.git
</IfModule>

ServerSignature Off
